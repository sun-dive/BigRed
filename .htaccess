# Cache policy (Apache / Namecheap cPanel). Covers are content-addressed by collection id → cache hard;
# the page/script/catalog are short-cached so curation edits propagate.
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|css|js|json)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>
